<?xml version="1.0" encoding="utf-8"?>
<!--
  RemoteViews поддерживает только ограниченный набор View:
  FrameLayout, LinearLayout, RelativeLayout, TextView, ImageView,
  ProgressBar, Button, ImageButton, Chronometer, AnalogClock.
  НЕТ: ConstraintLayout, вложенных адаптеров, кастомных View.
  Глубина вложенности: максимум 2 уровня для надёжности.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:background="@android:color/transparent">

    <!-- Статус: ○ / ✓ / 🛒 -->
    <TextView
        android:id="@+id/widget_item_check"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:textSize="14sp"
        android:gravity="center"
        android:text="○"
        android:textColor="#66FFFFFF"
        android:includeFontPadding="false" />

    <!-- Текст плана — основной -->
    <TextView
        android:id="@+id/widget_item_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="14sp"
        android:textColor="#FFFFFFFF"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginStart="10dp" />

    <!-- Время — справа, акцентный цвет, скрыто если нет времени -->
    <TextView
        android:id="@+id/widget_item_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#99FFFFFF"
        android:layout_marginStart="6dp"
        android:visibility="gone" />

</LinearLayout>
